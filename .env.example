# Quant GT login
QUANTGT_EMAIL=
QUANTGT_PASSWORD=

# Where runtime state, logs, output, screenshots, and browser profile live.
# Default: repository directory.
QUANTCHECK_HOME=

# Subscriber recipients only receive successful picks-update reports.
# NOTIFY_EMAIL_FILE may be absolute, or relative to QUANTCHECK_HOME.
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FILE=notify_recipients.txt

# Admin recipients receive all system/operator mail, plus successful picks updates.
# Admin mail includes scraper failures, health alerts, site/function changes,
# official-mail check/forward failures, and manual full-flow test emails.
NOTIFY_ADMIN_EMAIL_TO=
NOTIFY_ADMIN_EMAIL_FILE=notify_admin_recipients.txt

# SMTP sender, simplest standalone email option.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1
SMTP_STARTTLS=0

# Optional Gmail API sender. Leave disabled unless token.json is configured.
GMAIL_API_ENABLED=0
GMAIL_API_TOKEN=.config/gmail-api/token.json
GMAIL_API_FROM=

# Scheduler/runtime guards.
QUANTCHECK_SCAN_TIMEOUT_SECONDS=110
QUANTCHECK_HEALTH_TIMEOUT_SECONDS=110
QUANTCHECK_MAIL_TIMEOUT_SECONDS=60
QUANTCHECK_JITTER_SECONDS=5

# Optional: receive forwarded official Quant GT emails, then distribute them
# to picks-update recipients. You manually forward the subscription mailbox to
# this IMAP inbox; quantcheck handles detection, dedupe, and redistribution.
OFFICIAL_MAIL_ENABLED=0
OFFICIAL_MAIL_IMAP_HOST=
OFFICIAL_MAIL_IMAP_PORT=993
OFFICIAL_MAIL_IMAP_USERNAME=
OFFICIAL_MAIL_IMAP_PASSWORD=
OFFICIAL_MAIL_IMAP_MAILBOX=INBOX
OFFICIAL_MAIL_IMAP_SEARCH=UNSEEN
OFFICIAL_MAIL_SENDER_PATTERNS=@quantgt.io,quant gt,quantgt
OFFICIAL_MAIL_SUBJECT_PATTERNS=quant gt,quantgt,picks,holdings,portfolio
OFFICIAL_MAIL_MAX_MESSAGES=20

# Optional custom schedule. Format: HH:MM:kind,HH:MM:kind in America/New_York.
# kind is picks, health_site, health, or official_mail.
# QUANTCHECK_SCHEDULE=08:20:official_mail,08:30:picks,08:45:health_site,09:00:picks,09:20:official_mail,09:40:picks,12:00:official_mail,17:00:picks,17:15:health_site,17:30:official_mail
